set -e
BASEDIR=$(dirname "$(dirname "$0")")
if [ -z "$BASEDIR" ]; then
  BASEDIR=.
fi

MAVEN_WRAPPER_DIR="$BASEDIR/.mvn/wrapper"
MAVEN_WRAPPER_JAR="$MAVEN_WRAPPER_DIR/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_WRAPPER_DIR/maven-wrapper.properties"

if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  echo "Maven Wrapper JAR not found. To generate it, run on your machine:"
  echo "  mvn -N org.apache.maven.plugins:maven-wrapper:3.1.1:wrapper"
  echo "Or run the same command with your preferred Maven version."
  exit 1
fi

exec java -jar "$MAVEN_WRAPPER_JAR" "$@"

